# .env.example

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the
# correct URL for the current environment (dev or deployed).
APP_URL="https://example.run.app"

# EmailJS Configuration
# Get these from your EmailJS dashboard: https://dashboard.emailjs.com/
VITE_EMAILJS_SERVICE_ID="YOUR_SERVICE_ID"
VITE_EMAILJS_TEMPLATE_ID="YOUR_TEMPLATE_ID"
VITE_EMAILJS_PUBLIC_KEY="YOUR_PUBLIC_KEY"
